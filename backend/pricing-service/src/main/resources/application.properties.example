# Pricing Service Configuration
spring.application.name=pricing-service
server.port=8081

# PostgreSQL
spring.datasource.url=${DB_URL:jdbc:postgresql://localhost:5432/pricingdb}
spring.datasource.driver-class-name=org.postgresql.Driver
spring.datasource.username=${DB_USERNAME:ctse}
spring.datasource.password=${DB_PASSWORD:ctse_password}

# JPA / Hibernate
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true

# gRPC server port
grpc.server.port=9091
grpc.server.address=0.0.0.0
