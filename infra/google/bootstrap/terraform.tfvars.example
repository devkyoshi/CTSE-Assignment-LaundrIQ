# Copy to terraform.tfvars — never commit that file.
#
# Pre-requisite (one gcloud command, run once):
#   gcloud storage buckets create gs://YOUR_BUCKET_NAME \
#     --location=us-central1 --uniform-bucket-level-access
#   gcloud storage buckets update gs://YOUR_BUCKET_NAME --versioning
#
# Then:
#   terraform init -backend-config="bucket=YOUR_BUCKET_NAME"
#   terraform apply -var-file=terraform.tfvars

project_id      = "your-gcp-project-id"
region          = "us-central1"
tf_state_bucket = "your-tf-state-bucket-name"

github_owner = "silverviles"
github_repo  = "CTSE-Assignment-LaundrIQ"
github_token = "ghp_..."   # https://github.com/settings/tokens → repo scope

db_password            = ""
jwt_secret             = ""
admin_password         = ""
stripe_secret_key      = ""
stripe_webhook_secret  = ""
stripe_publishable_key = ""
